---
interface Props {
  message: string
}

const { message } = Astro.props
---

<div
  role="alert"
  class="relative grid w-full gap-1 rounded-lg border bg-card px-4 py-3 text-sm text-destructive"
>
  <div class="font-medium">Something went wrong</div>
  <div class="text-sm text-destructive/90">{message}</div>
  <div class="mt-3">
    <a
      href={Astro.url.pathname}
      class="inline-flex h-8 items-center justify-center rounded-lg border border-border bg-background px-3 text-sm font-medium transition-all hover:bg-muted hover:text-foreground"
    >
      Retry
    </a>
  </div>
</div>
